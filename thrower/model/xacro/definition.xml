
<link
  name="slider">
  <inertial>
    <origin
      xyz="0 0 0"
      rpy="0 0 0" />
    <mass
      value="0.5" />
    <inertia
      ixx="1.6E-04"
      ixy="0"
      ixz="0"
      iyy="1.1E-04"
      iyz="0"
      izz="6.5E-05" />
  </inertial>
  <xacro:box_visual size="0.05 0.05 0.1"/>
  <xacro:box_collision size="0.05 0.05 0.1"/>
</link>

<joint
  name="connector_joint"
  type="fixed">
  <origin
    xyz="0 0 0"
    rpy="0 0 0" />
  <parent
    link="slider" />
  <child
    link="hip" />
  <axis
    xyz="0 0 0" />
</joint>

