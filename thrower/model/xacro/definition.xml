</link>

<joint
  name="hip_joint"
  type="revolute">
  <origin
    xyz="0 0 ${-0.1/2}" 
    rpy="0 0 0" />
  <parent
    link="hip" />
  <child
    link="link_0" />
  <axis
    xyz="0 1 0" />
  <limit
    effort="12"
    velocity="38.2" />
</joint>

